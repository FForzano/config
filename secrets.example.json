{
  "env_vars": [
    {"name": "AWS_PROFILE", "value": "your-aws-profile"},
    {"name": "PHP_VERSION", "value": "8.5"}
  ],
  "ssh_hosts": [
    {
      "alias": "github.com",
      "hostname": "github.com",
      "user": "git"
    },
    {
      "alias": "my-server",
      "hostname": "192.168.1.100",
      "user": "myuser"
    },
    {
      "alias": "proxied-server",
      "hostname": "ssh.example.com",
      "user": "myuser",
      "proxy_command": "    ProxyCommand cloudflared access ssh --hostname %h",
      "preferred_authentications": "    PreferredAuthentications password",
      "pubkey_authentication": "    PubkeyAuthentication no"
    }
  ]
}
