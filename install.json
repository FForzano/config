{
  "components": [
    {
      "id": "zsh",
      "name": "Zsh",
      "description": "Shell config (zshrc + Powerlevel10k theme)",
      "os": ["macos", "linux"],
      "actions": [
        {
          "type": "shell",
          "cmd":   { "linux": "sudo apt install -y zsh" },
          "check": "command -v zsh &>/dev/null"
        },
        {
          "type": "shell",
          "cmd":   { "linux": "chsh -s $(which zsh)" },
          "check": "getent passwd \"$USER\" | cut -d: -f7 | grep -q zsh"
        },
        {
          "type": "shell",
          "cmd":   "RUNZSH=no CHSH=no sh -c \"$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)\"",
          "check": "[ -d \"$HOME/.oh-my-zsh\" ]"
        },
        {
          "type": "shell",
          "cmd":   "git clone --depth=1 https://github.com/romkatv/powerlevel10k.git \"${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/themes/powerlevel10k\"",
          "check": "[ -d \"$HOME/.oh-my-zsh/custom/themes/powerlevel10k\" ]"
        },
        { "type": "link", "src": "Mac/zshrc",    "dst": "~/.zshrc"    },
        { "type": "link", "src": "Mac/p10k.zsh", "dst": "~/.p10k.zsh" }
      ]
    },
    {
      "id": "zsh-local",
      "name": "Zsh local",
      "description": "Machine-specific env vars (~/.zshrc.local) from secrets.json",
      "os": ["macos", "linux"],
      "actions": [
        {
          "type": "generate",
          "dst": "~/.zshrc.local",
          "from": "env_vars",
          "template": "export {{name}}={{value}}\n"
        }
      ]
    },
    {
      "id": "ghostty",
      "name": "Ghostty",
      "description": "Terminal emulator configuration",
      "os": ["macos"],
      "actions": [
        {
          "type": "shell",
          "cmd":   { "macos": "brew install --cask ghostty" },
          "check": "[ -d '/Applications/Ghostty.app' ]"
        },
        { "type": "link", "src": "Mac/ghostty/config", "dst": "~/Library/Application Support/com.mitchellh.ghostty/config" }
      ]
    },
    {
      "id": "hammerspoon",
      "name": "Hammerspoon",
      "description": "macOS automation framework (window management, hotkeys)",
      "os": ["macos"],
      "actions": [
        {
          "type": "shell",
          "cmd":   { "macos": "brew install --cask hammerspoon" },
          "check": "[ -d '/Applications/Hammerspoon.app' ]"
        },
        { "type": "link", "src": "Mac/hammerspoon", "dst": "~/.hammerspoon" }
      ]
    },
    {
      "id": "ssh",
      "name": "SSH",
      "description": "SSH client configuration (hosts, keys, options)",
      "os": ["macos", "linux"],
      "actions": [
        {
          "type": "shell",
          "cmd":   { "macos": "brew install cloudflared" },
          "check": "command -v cloudflared &>/dev/null"
        },
        { "type": "mkdir", "path": "~/.ssh", "mode": "700" },
        { "type": "link",  "src": "Mac/ssh/config", "dst": "~/.ssh/config" },
        {
          "type": "generate",
          "dst": "~/.ssh/config.private",
          "from": "ssh_hosts",
          "template": "Host {{alias}}\n    HostName {{hostname}}\n{{proxy_command}}\n    User {{user}}\n    IdentityAgent SSH_AUTH_SOCK\n{{preferred_authentications}}\n{{pubkey_authentication}}\n"
        }
      ]
    },
    {
      "id": "mc",
      "name": "Midnight Commander",
      "description": "File manager config + mashdark theme",
      "os": ["macos", "linux"],
      "actions": [
        {
          "type": "shell",
          "cmd":   { "macos": "brew install midnight-commander", "linux": "sudo apt install -y mc" },
          "check": "command -v mc &>/dev/null"
        },
        { "type": "link",  "src": "Mac/config/mc", "dst": "~/.config/mc" },
        { "type": "mkdir", "path": "~/.local/share/mc/skins" },
        { "type": "link",  "src": "Mac/local/share/mc/skins/mashdark.ini", "dst": "~/.local/share/mc/skins/mashdark.ini" }
      ]
    },
    {
      "id": "lima",
      "name": "Lima",
      "description": "Docker-enabled Linux VM (limactl start)",
      "os": ["macos"],
      "actions": [
        {
          "type": "shell",
          "cmd":   { "macos": "brew install lima" },
          "check": "command -v limactl &>/dev/null"
        },
        {
          "type": "shell",
          "cmd":   { "macos": "limactl start '{ROOT}/Mac/lima/dockerimg/lima.yaml'" },
          "check": "limactl list 2>/dev/null | grep -q 'dockerimg'"
        }
      ]
    },
    {
      "id": "launchagents",
      "name": "LaunchAgents",
      "description": "Bitwarden SSH environment variables agent",
      "os": ["macos"],
      "actions": [
        { "type": "link", "src": "Mac/Library/LaunchAgents/bitwarden-ssh-env.plist", "dst": "~/Library/LaunchAgents/bitwarden-ssh-env.plist" },
        {
          "type": "shell",
          "cmd":   { "macos": "launchctl bootout gui/$(id -u)/bitwarden-ssh-env 2>/dev/null || true; launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/bitwarden-ssh-env.plist" },
          "check": "launchctl list 2>/dev/null | grep -q 'bitwarden-ssh-env'"
        }
      ]
    }
  ]
}
